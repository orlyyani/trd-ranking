# ── Supabase ──────────────────────────────────────────────────────────────────
# Local:      from `supabase status` (Publishable / Secret keys)
# Production: from supabase.com → Project Settings → API

SUPABASE_URL=
SUPABASE_ANON_KEY=

# Mirrors the above — required by @nuxtjs/supabase for Nuxt's public runtime config
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service role key — bypasses RLS. NEVER expose to the client.
# Local: "Secret" key from `supabase status`
# Production: "service_role" key from supabase.com → Project Settings → API
SUPABASE_SERVICE_KEY=

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Optional — only needed for player photo uploads.
# Cloud name:    Cloudinary dashboard → top-right account menu
# Upload preset: Settings → Upload → Upload presets → create an Unsigned preset
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# ── Challonge ─────────────────────────────────────────────────────────────────
# API key from challonge.com → Settings → Developer API
CHALLONGE_API_KEY=

# One or more tournaments — comma-separated "Display Name:slug" pairs.
# The slug is the last part of the tournament URL: challonge.com/{slug}
# Single:   CHALLONGE_TOURNAMENT_URLS=53yr35ik
# Multiple: CHALLONGE_TOURNAMENT_URLS=Class C:53yr35ik,Beginners:abc456
CHALLONGE_TOURNAMENT_URLS=

# Community subdomain for fetching upcoming/in-progress tournaments.
# Found in: challonge.com/communities/{subdomain}/tournaments
CHALLONGE_COMMUNITY=therallydistrict